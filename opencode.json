{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "Grok Code Fast 1",
      "prompt": "{file:./prompts/build.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "description": "Agent responsible for building and deploying the application",
      "temperature": 0.3
    },
    "plan": {
      "mode": "primary",
      "model": "Claude Opus 4.6",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "description": "Agent for planning features and tasks",
      "temperature": 0.1
    },
    "review": {
      "mode": "subagent",
      "model": "Grok Code Fast 1",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "description": "Agent for code review and quality assurance",
      "temperature": 0.1
    }
  }
}