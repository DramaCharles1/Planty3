{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      }
    }
  },
  "agent": {
    "build": {
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "{file:./prompts/build.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "description": "Agent responsible for building and deploying the application",
      "temperature": 0.3
    },
    "Expensive plan": {
      "model": "github-copilot/claude-opus-4.6",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "description": "Agent for planning features and tasks",
      "temperature": 0.1
    },
    "Cheap plan": {
      "model": "github-copilot/claude-sonnet-4.5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "description": "Agent for planning features and tasks",
      "temperature": 0.1
    },
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "{file:./prompts/code-reviewer.txt}",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  }
}
